# ===============================
# Database
# ===============================
MONGODB_URI=mongodb_uri

# ===============================
# JWT
# ===============================
JWT_SECRET=your_jwt_access_secret
JWT_EXPIRATION=jwt_expiration_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRATION=jwt_refreshh_expiration_secret

# ===============================
# Cookies
# ===============================
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
ACCESS_TOKEN_EXPIRATION_MS=access_token_expiration_ms_secret
REFRESH_TOKEN_EXPIRATION_MS=refresh_token_expiration_ms_secret

# ===============================
# Brevo (Email Service)
# ===============================
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=no-reply@yourdomain.com
BREVO_SENDER_NAME=YourAppName
FRONTEND_URL=http://localhost:3000
LOGO_URL=https://yourdomain.com/logo.png

# ===============================
# Google OAuth
# ===============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ===============================
# GitHub OAuth
# ===============================
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# ===============================
# Gemini API
# ===============================
GEMINI_API_KEY=your_gemini_api_key

# Rate Limiting
THROTTLE_TTL=throttle_ttl_secret
THROTTLE_LIMIT=throttle_limit_secret

# ===============================
# Server
# ===============================
PORT=3000
NODE_ENV=development
API_PREFIX=api